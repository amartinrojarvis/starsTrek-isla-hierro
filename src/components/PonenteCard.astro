---
import type { CollectionEntry } from 'astro:content';

interface Props {
  ponente: CollectionEntry<'ponentes'>;
}

const { ponente } = Astro.props;
const { nombre, rol, fotoRetrato, bio, instagram, web } = ponente.data;
---

<div class="group relative bg-gradient-to-br from-white/5 to-white/[0.02] rounded-2xl sm:rounded-3xl overflow-hidden border border-white/10 hover:border-accent/50 transition-all duration-500 hover:shadow-[0_0_60px_rgba(59,130,246,0.2)]">
  <!-- Glow effect -->
  <div class="absolute inset-0 bg-gradient-to-br from-accent/0 to-starlight/0 group-hover:from-accent/10 group-hover:to-starlight/10 transition-all duration-500"></div>
  
  <div class="relative p-4 sm:p-6 lg:p-8">
    <div class="flex flex-col lg:flex-row gap-4 sm:gap-6 lg:gap-8">
      <!-- Foto de retrato -->
      <div class="lg:w-1/3 flex-shrink-0">
        <div class="relative aspect-[3/4] max-w-[200px] sm:max-w-none mx-auto lg:mx-0 rounded-xl sm:rounded-2xl overflow-hidden bg-gradient-to-br from-accent/20 to-starlight/20">
          {fotoRetrato ? (
            <img 
              src={fotoRetrato} 
              alt={nombre}
              class="w-full h-full object-cover object-center transform group-hover:scale-110 transition-transform duration-700"
            />
          ) : (
            <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-accent/10 to-starlight/10">
              <span class="text-4xl sm:text-6xl">👤</span>
            </div>
          )}
          <!-- Overlay con gradiente -->
          <div class="absolute inset-0 bg-gradient-to-t from-primary/80 via-transparent to-transparent"></div>
        </div>
      </div>
      
      <!-- Info -->
      <div class="lg:w-2/3 flex flex-col justify-center text-center lg:text-left">
        <h3 class="text-xl sm:text-2xl lg:text-3xl font-display font-bold mb-1 sm:mb-2 bg-gradient-to-r from-white to-gray-300 bg-clip-text text-transparent">
          {nombre}
        </h3>
        <p class="text-accent font-semibold text-base sm:text-lg mb-3 sm:mb-4">{rol}</p>
        <p class="text-gray-400 text-sm sm:text-base leading-relaxed mb-4 sm:mb-6">{bio}</p>
        
        <!-- Botones -->
        <div class="flex flex-col sm:flex-row flex-wrap gap-2 sm:gap-4 justify-center lg:justify-start">
          <a 
            href={`/galeria/${ponente.slug}`}
            class="inline-flex items-center justify-center gap-2 px-4 sm:px-6 py-2.5 sm:py-3 bg-gradient-to-r from-accent to-starlight rounded-full font-semibold text-white text-sm sm:text-base hover:shadow-[0_0_20px_rgba(59,130,246,0.4)] transition-all duration-300 transform hover:scale-105"
          >
            <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            Ver Galería
          </a>
          
          {instagram && (
            <a 
              href={instagram}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center justify-center gap-2 px-4 sm:px-6 py-2.5 sm:py-3 border border-white/20 rounded-full font-semibold text-white text-sm sm:text-base hover:bg-white/10 transition-all duration-300"
            >
              <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
              Instagram
            </a>
          )}
          
          {web && (
            <a 
              href={web}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center justify-center gap-2 px-4 sm:px-6 py-2.5 sm:py-3 border border-white/20 rounded-full font-semibold text-white text-sm sm:text-base hover:bg-white/10 transition-all duration-300"
            >
              <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
              </svg>
              Web
            </a>
          )}
        </div>
      </div>
    </div>
  </div>
</div>
