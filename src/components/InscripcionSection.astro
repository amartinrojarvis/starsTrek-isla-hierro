---
---

<section id="inscripcion" class="py-16 sm:py-24 relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-cosmic via-primary to-cosmic"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-accent/20 via-transparent to-transparent"></div>
  
  <!-- Animated background stars -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    {[...Array(20)].map((_, i) => (
      <div 
        class="absolute w-0.5 h-0.5 sm:w-1 sm:h-1 bg-white rounded-full animate-pulse"
        style={{
          left: `${Math.random() * 100}%`,
          top: `${Math.random() * 100}%`,
          animationDelay: `${Math.random() * 4}s`,
        }}
      />
    ))}
  </div>
  
  <div class="relative max-w-4xl mx-auto px-4 text-center">
    <span class="inline-block px-3 sm:px-4 py-1 rounded-full bg-accent/20 text-accent text-xs sm:text-sm font-bold mb-4 sm:mb-6 animate-pulse">
      Plazas Limitadas
    </span>
    
    <h2 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-display font-bold mb-4 sm:mb-6 bg-gradient-to-r from-white via-starlight to-accent bg-clip-text text-transparent px-2">
      Inscríbete a StarsTrek
    </h2>
    
    <p class="text-base sm:text-lg md:text-xl text-gray-400 mb-8 sm:mb-12 max-w-2xl mx-auto px-4">
      Una experiencia única bajo el cielo Starlight de La Frontera, El Hierro
    </p>
    
    <div class="bg-gradient-to-br from-white/10 to-white/5 rounded-2xl sm:rounded-3xl p-5 sm:p-8 md:p-10 lg:p-12 border border-accent/30 backdrop-blur-xl mb-8 sm:mb-12">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 sm:gap-8 mb-6 sm:mb-8">
        <div class="text-center">
          <div class="w-12 h-12 sm:w-16 sm:h-16 mx-auto mb-3 sm:mb-4 rounded-full bg-gradient-to-br from-accent to-starlight flex items-center justify-center text-xl sm:text-2xl">
            📅
          </div>
          <p class="text-xl sm:text-2xl font-bold text-white mb-1">5-7</p>
          <p class="text-gray-400 text-sm sm:text-base">Junio 2026</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 sm:w-16 sm:h-16 mx-auto mb-3 sm:mb-4 rounded-full bg-gradient-to-br from-gold to-accent flex items-center justify-center text-xl sm:text-2xl">
            📍
          </div>
          <p class="text-lg sm:text-xl font-bold text-white mb-1">La Frontera</p>
          <p class="text-gray-400 text-sm sm:text-base">El Hierro ★</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 sm:w-16 sm:h-16 mx-auto mb-3 sm:mb-4 rounded-full bg-gradient-to-br from-starlight to-accent flex items-center justify-center text-xl sm:text-2xl">
            👥
          </div>
          <p class="text-lg sm:text-xl font-bold text-white mb-1">Grupos</p>
          <p class="text-gray-400 text-sm sm:text-base">Reducidos</p>
        </div>
      </div>
      
      <div class="space-y-2 sm:space-y-3 mb-6 sm:mb-8 text-left max-w-md mx-auto px-2 sm:px-0">
        {[
          'Acceso a todas las ponencias',
          'Participación en talleres prácticos',
          'Observación astronómica con telescopio',
          'Materiales del congreso',
          'Certificado de asistencia',
          'Cóctel de bienvenida'
        ].map((item) => (
          <div class="flex items-center gap-2 sm:gap-3">
            <span class="w-5 h-5 sm:w-6 sm:h-6 rounded-full bg-gradient-to-br from-accent to-starlight flex items-center justify-center text-xs sm:text-sm flex-shrink-0">✓</span>
            <span class="text-gray-300 text-sm sm:text-base">{item}</span>
          </div>
        ))}
      </div>
      
      <a href="#" 
         class="inline-block w-full sm:w-auto px-6 sm:px-12 py-3.5 sm:py-5 bg-gradient-to-r from-accent via-starlight to-accent rounded-full text-base sm:text-xl font-bold text-white hover:shadow-[0_0_50px_rgba(59,130,246,0.6)] transition-all duration-500 transform hover:scale-105 bg-[length:200%_auto] hover:bg-[position:right_center]">
        Reservar Mi Plaza Ahora
      </a>
      
      <p class="text-gray-500 mt-4 sm:mt-6 text-xs sm:text-sm">
        Municipio Starlight · Reserva de la Biosfera · Calidad del cielo excepcional
      </p>
    </div>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6 text-left">
      <div class="bg-white/5 rounded-xl sm:rounded-2xl p-4 sm:p-6 border border-white/10 backdrop-blur-sm">
        <h4 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3 text-gold">¿Dónde?</h4>
        <p class="text-gray-400 leading-relaxed text-sm sm:text-base">
          La Frontera, El Hierro<br>
          Islas Canarias, España<br>
          <span class="text-starlight">★ Municipio Starlight certificado</span>
        </p>
      </div>
      <div class="bg-white/5 rounded-xl sm:rounded-2xl p-4 sm:p-6 border border-white/10 backdrop-blur-sm">
        <h4 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3 text-gold">Contacto</h4>
        <p class="text-gray-400 leading-relaxed text-sm sm:text-base">
          info@fototrek.es<br>
          <a href="https://instagram.com/starstrek" class="text-accent hover:text-white transition-colors">@starstrek</a>
        </p>
      </div>
    </div>
  </div>
</section>
