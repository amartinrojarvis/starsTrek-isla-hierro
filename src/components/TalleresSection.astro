---
import { getCollection } from 'astro:content';

const talleres = await getCollection('talleres');
---

<section id="talleres" class="py-16 sm:py-24 relative">
  <div class="absolute inset-0 bg-gradient-to-b from-primary via-cosmic to-primary"></div>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-stops))] from-gold/5 via-transparent to-transparent"></div>
  
  <div class="relative max-w-6xl mx-auto px-4">
    <div class="text-center mb-10 sm:mb-16">
      <span class="inline-block px-4 py-1 rounded-full bg-gold/10 text-gold text-xs sm:text-sm font-semibold mb-4">
        100% Práctico
      </span>
      <h2 class="text-4xl sm:text-5xl md:text-6xl font-display font-bold mb-4 sm:mb-6 bg-gradient-to-r from-white via-gold to-accent bg-clip-text text-transparent">
        Talleres
      </h2>
      <p class="text-gray-400 text-base sm:text-lg max-w-2xl mx-auto px-4">
        Aprendizaje hands-on bajo el cielo de El Hierro con grupos reducidos
      </p>
    </div>
    
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 sm:gap-6 lg:gap-8">
      {talleres.map((taller) => (
        <div class={`group relative bg-gradient-to-br from-white/5 to-white/[0.02] rounded-2xl sm:rounded-3xl p-5 sm:p-6 lg:p-8 border transition-all duration-500 hover:shadow-[0_0_40px_rgba(251,191,36,0.2)] ${
          taller.data.destacado ? 'border-gold/50' : 'border-white/10 hover:border-gold/50'
        }`}>
          <div class="absolute inset-0 bg-gradient-to-br from-gold/0 to-accent/0 group-hover:from-gold/5 group-hover:to-accent/5 rounded-2xl sm:rounded-3xl transition-all duration-500"></div>
          
          <div class="relative">
            <div class="flex items-start justify-between gap-3 mb-3 sm:mb-4">
              <div class="flex-1 min-w-0">
                <span class="inline-block px-2 sm:px-3 py-0.5 sm:py-1 bg-gold/20 text-gold text-xs font-bold rounded-full mb-2 sm:mb-3">
                  {taller.data.fecha} · {taller.data.hora}
                </span>
                <h3 class="text-lg sm:text-xl lg:text-2xl font-bold text-white group-hover:text-gold transition-colors leading-tight">
                  {taller.data.titulo}
                </h3>
              </div>
              {taller.data.destacado && (
                <span class="text-2xl sm:text-3xl flex-shrink-0">★</span>
              )}
            </div>
            
            <p class="text-starlight font-semibold text-sm sm:text-base mb-3 sm:mb-4">{taller.data.instructor}</p>
            
            <p class="text-gray-400 text-sm sm:text-base mb-4 sm:mb-6 leading-relaxed">
              {taller.data.descripcion}
            </p>
            
            <div class="flex flex-wrap gap-1.5 sm:gap-2 mb-4 sm:mb-6">
              {taller.data.requisitos.map((req) => (
                <span class="px-2 sm:px-3 py-0.5 sm:py-1 bg-white/5 text-gray-300 text-xs sm:text-sm rounded-full border border-white/10">
                  {req}
                </span>
              ))}
            </div>
            
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 sm:gap-4 pt-3 sm:pt-4 border-t border-white/10">
              <div class="flex gap-3 sm:gap-4 text-xs sm:text-sm text-gray-400">
                <span>⏱️ {taller.data.duracion}</span>
                <span>👥 {taller.data.aforo}</span>
              </div>
              <a href="#inscripcion" class="text-gold font-semibold hover:text-white transition-colors flex items-center justify-center sm:justify-start gap-1 text-sm">
                Reservar plaza
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
