---
---

<section id="inicio" class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16">
  <!-- Background Effects -->
  <div class="absolute inset-0 bg-gradient-to-b from-primary via-cosmic to-primary"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-accent/20 via-transparent to-transparent"></div>
  
  <!-- Animated Stars -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    {[...Array(50)].map((_, i) => (
      <div 
        class="absolute w-1 h-1 bg-white rounded-full animate-pulse"
        style={{
          left: `${Math.random() * 100}%`,
          top: `${Math.random() * 100}%`,
          animationDelay: `${Math.random() * 4}s`,
          opacity: Math.random() * 0.8 + 0.2,
        }}
      />
    ))}
    {/* Shooting stars */}
    <div class="absolute top-20 left-10 w-20 h-0.5 bg-gradient-to-r from-transparent via-white to-transparent transform -rotate-45 animate-[shoot_3s_ease-out_infinite] opacity-0"></div>
    <div class="absolute top-40 right-20 w-20 h-0.5 bg-gradient-to-r from-transparent via-starlight to-transparent transform -rotate-45 animate-[shoot_4s_ease-out_infinite_1s] opacity-0"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-6xl mx-auto px-4 text-center">
    <!-- Badge Starlight -->
    <div class="inline-block mb-4 px-4 py-1.5 rounded-full bg-white/5 border border-white/10 backdrop-blur-sm">
      <span class="text-starlight font-bold tracking-wider text-xs sm:text-sm uppercase">★ Municipio Starlight ★</span>
    </div>
    
    <!-- Fecha -->
    <p class="text-accent font-bold tracking-[0.2em] uppercase mb-4 sm:mb-6 text-xs sm:text-sm animate-fade-in">
      5-7 de Junio 2026
    </p>
    
    <!-- LOGO GRANDE -->
    <div class="mb-6 sm:mb-8 flex justify-center px-4">
      <img 
        src="https://www.fototrek.es/images/2026/04/09/logotipo-starstrek-letra-blanca.png" 
        alt="StarsTrek Isla del Hierro"
        class="w-full max-w-[280px] sm:max-w-[400px] md:max-w-[500px] lg:max-w-[600px] h-auto drop-shadow-[0_0_30px_rgba(59,130,246,0.6)]"
      />
    </div>
    
    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center items-center px-4">
      <a href="#inscripcion" 
         class="w-full sm:w-auto group relative px-6 sm:px-10 py-3 sm:py-4 bg-gradient-to-r from-accent to-starlight rounded-full text-base sm:text-lg font-bold text-white overflow-hidden transition-all duration-300 hover:shadow-[0_0_40px_rgba(59,130,246,0.6)] hover:scale-105">
        <span class="relative z-10">Reservar Mi Plaza</span>
        <div class="absolute inset-0 bg-gradient-to-r from-starlight to-accent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
      </a>
      <a href="#programa" 
         class="w-full sm:w-auto px-6 sm:px-10 py-3 sm:py-4 border border-white/30 rounded-full text-base sm:text-lg font-bold text-white hover:bg-white/10 transition-all duration-300 backdrop-blur-sm text-center">
        Ver Programa
      </a>
    </div>
    
    <!-- Stats -->
    <div class="mt-8 sm:mt-12 grid grid-cols-3 gap-4 sm:gap-8 max-w-lg mx-auto px-4">
      <div class="text-center">
        <p class="text-2xl sm:text-4xl md:text-5xl font-bold text-accent mb-1">4</p>
        <p class="text-gray-400 text-xs sm:text-sm uppercase tracking-wider">Ponentes</p>
      </div>
      <div class="text-center">
        <p class="text-2xl sm:text-4xl md:text-5xl font-bold text-gold mb-1">3</p>
        <p class="text-gray-400 text-xs sm:text-sm uppercase tracking-wider">Días</p>
      </div>
      <div class="text-center">
        <p class="text-2xl sm:text-4xl md:text-5xl font-bold text-starlight mb-1">★</p>
        <p class="text-gray-400 text-xs sm:text-sm uppercase tracking-wider">Starlight</p>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-6 sm:bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
    <div class="w-5 sm:w-6 h-8 sm:h-10 border-2 border-white/30 rounded-full flex justify-center pt-1.5 sm:pt-2">
      <div class="w-1 h-2 sm:h-3 bg-accent rounded-full animate-pulse"></div>
    </div>
  </div>

  <style>
    @keyframes shoot {
      0% { transform: translateX(0) translateY(0) rotate(-45deg); opacity: 1; }
      100% { transform: translateX(300px) translateY(300px) rotate(-45deg); opacity: 0; }
    }
  </style>
</section>
