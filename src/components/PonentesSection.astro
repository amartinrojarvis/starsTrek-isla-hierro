---
import { getCollection } from 'astro:content';
import PonenteCard from './PonenteCard.astro';

const ponentes = await getCollection('ponentes');
ponentes.sort((a, b) => a.data.orden - b.data.orden);
---

<section id="ponentes" class="py-24 relative overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-b from-primary via-cosmic to-primary"></div>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-stops))] from-accent/5 via-transparent to-transparent"></div>
  
  <div class="relative max-w-6xl mx-auto px-4">
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1 rounded-full bg-accent/10 text-accent text-sm font-semibold mb-4">
        Expertos Internacionales
      </span>
      <h2 class="text-5xl md:text-6xl font-display font-bold mb-6 bg-gradient-to-r from-white via-starlight to-accent bg-clip-text text-transparent">
        Ponentes
      </h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">
        Aprende de los mejores fotógrafos nocturnos y divulgadores astronómicos del panorama nacional
      </p>
    </div>
    
    <div class="space-y-8">
      {ponentes.map((ponente) => (
        <PonenteCard ponente={ponente} />
      ))}
    </div>
  </div>
</section>
