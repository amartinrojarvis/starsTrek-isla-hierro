---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import ProgramaSection from '../components/ProgramaSection.astro';
import PonentesSection from '../components/PonentesSection.astro';
import TalleresSection from '../components/TalleresSection.astro';
import InscripcionSection from '../components/InscripcionSection.astro';
import Footer from '../components/Footer.astro';

const title = "StarsTrek Isla del Hierro | Congreso de Fotografía Nocturna";
const description = "Congreso de fotografía nocturna en La Frontera, El Hierro. 5-7 de junio 2026. Ponentes internacionales, talleres prácticos y observación astronómica en municipio Starlight.";
---

<Layout title={title} description={description}>
  <Navigation />
  <Hero />
  <ProgramaSection />
  <PonentesSection />
  <TalleresSection />
  <InscripcionSection />
  <Footer />
</Layout>

<script>
  // Smooth scroll for navigation links
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
      e.preventDefault();
      const target = document.querySelector(this.getAttribute('href'));
      if (target) {
        target.scrollIntoView({
          behavior: 'smooth',
          block: 'start'
        });
      }
    });
  });
</script>
