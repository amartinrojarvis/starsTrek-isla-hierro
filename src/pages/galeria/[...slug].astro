---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const ponentes = await getCollection('ponentes');
  return ponentes.map((ponente) => ({
    params: { slug: ponente.slug },
    props: { ponente },
  }));
}

const { ponente } = Astro.props;
const { nombre, rol, galeria } = ponente.data;
const { Content } = await ponente.render();
---

<Layout title={`Galería de ${nombre} | StarsTrek`}>
  <!-- Header -->
  <div class="fixed top-0 w-full z-50 bg-primary/90 backdrop-blur-xl border-b border-white/10">
    <div class="max-w-7xl mx-auto px-4 py-4 flex items-center justify-between">
      <a href="/#ponentes" class="flex items-center gap-2 text-gray-400 hover:text-white transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        Volver a Ponentes
      </a>
      <img src="https://www.fototrek.es/images/2026/04/09/logotipo-starstrek-letra-blanca.png" alt="StarsTrek" class="h-10">
    </div>
  </div>

  <!-- Main Content -->
  <main class="pt-24 pb-16 min-h-screen bg-gradient-to-b from-primary via-cosmic to-primary">
    <div class="max-w-7xl mx-auto px-4">
      <!-- Header -->
      <div class="text-center mb-12">
        <h1 class="text-5xl md:text-6xl font-display font-bold mb-4 bg-gradient-to-r from-white via-starlight to-accent bg-clip-text text-transparent">
          {nombre}
        </h1>
        <p class="text-xl text-accent">{rol}</p>
      </div>
      
      <!-- Bio -->
      <div class="max-w-3xl mx-auto mb-16 text-center">
        <div class="prose prose-invert prose-lg mx-auto">
          <Content />
        </div>
      </div>
      
      <!-- Gallery Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {galeria.map((foto, index) => (
          <div class="group relative aspect-[4/3] rounded-2xl overflow-hidden bg-gradient-to-br from-white/5 to-white/[0.02] border border-white/10 hover:border-accent/50 transition-all duration-500 cursor-pointer">
            {foto.url ? (
              <img 
                src={foto.url} 
                alt={foto.titulo || `Foto ${index + 1}`}
                class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-700"
              />
            ) : (
              <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-accent/10 to-starlight/10">
                <span class="text-6xl">📷</span>
              </div>
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-primary/90 via-primary/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <div class="absolute bottom-0 left-0 right-0 p-4 translate-y-full group-hover:translate-y-0 transition-transform duration-300">
              <p class="text-white font-semibold">{foto.titulo || `Fotografía ${index + 1}`}</p>
            </div>
          </div>
        ))}
      </div>
      
      <!-- Back button -->
      <div class="text-center mt-12">
        <a href="/#ponentes" 
           class="inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-accent to-starlight rounded-full font-bold text-white hover:shadow-[0_0_30px_rgba(59,130,246,0.5)] transition-all duration-300 transform hover:scale-105">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
          </svg>
          Volver a Ponentes
        </a>
      </div>
    </div>
  </main>
</Layout>
